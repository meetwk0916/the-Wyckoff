    "crypto:probe": "node crypto-workspace/src/runProviderProbe.mjs",
    "crypto:ws-probe": "node crypto-workspace/src/runWsProbe.mjs",
    "crypto:rest-capture": "node crypto-workspace/src/runRestCapture.mjs",
    "crypto:capture": "node crypto-workspace/src/runLiveCapture.mjs",
