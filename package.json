    "crypto:replay": "node crypto-workspace/src/runReplayWindow.mjs",
    "crypto:fixtures": "node crypto-workspace/src/runReplayFixtures.mjs",
    "crypto:phase-c:evidence": "node crypto-workspace/src/runPhaseCEvidence.mjs",
    "crypto:phase-c:classify": "node crypto-workspace/src/runPhaseCClassify.mjs",
    "crypto:phase-c:review": "node crypto-workspace/src/runPhaseCReview.mjs",
    "crypto:phase-c:verify": "node crypto-workspace/src/runPhaseCVerify.mjs",
